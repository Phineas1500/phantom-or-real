# Copy to .env in the project root. The loader at src/env_loader.py reads this
# automatically; nothing is ever written back or committed (.env is gitignored).

# ==========================================
# 1. Hugging Face (local Gemma 3 4B via vLLM)
# ==========================================
# Accept license first: https://huggingface.co/google/gemma-3-4b-it
HF_TOKEN=hf_your_huggingface_token_here

# ==========================================
# 2. Primary inference endpoint (Gemma 3 27B)
# ==========================================
# Modal (recommended per project plan): paste the URL `modal deploy` prints,
# ending in `.modal.run`, and append `/v1` for the OpenAI-compatible path.
# Modal endpoints don't check an API key, so OPENAI_API_KEY can be any string.
#
#   OPENAI_BASE_URL=modal-url
#   OPENAI_API_KEY=not-needed
#
# Alternatively, OpenRouter:
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   OPENAI_API_KEY=sk-or-v1-...

OPENAI_BASE_URL=modal-url
OPENAI_API_KEY=not-needed

# ==========================================
# 3. OpenAI proper (Phase 5 error classification, gpt-5.4-mini)
# ==========================================
# Kept on a separate variable so it doesn't collide with the inference key above.
# src/error_classification.py reads OPENAI_API_KEY_GPT first and only falls back
# to OPENAI_API_KEY if it isn't set.
OPENAI_API_KEY_GPT=sk-proj-your_openai_key_here

# Optional: override the OpenAI base URL for the judge (default: api.openai.com)
# OPENAI_BASE_URL_GPT=
