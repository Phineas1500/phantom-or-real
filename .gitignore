# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/

# Virtual envs
.venv/
venv/

# Data and results. Most of this is scratch / redundant; we track only the
# primary handoff artifacts so teammates can clone and read the dataset
# directly.
data/*
!data/full/
data/full/*
!data/full/*.pkl
!data/pilot/
data/pilot/*
!data/pilot/*.pkl

results/*
!results/full/
results/full/*
!results/full/with_errortype/
!results/full/*.json
!results/error_agreement_4b.json
results/full/with_errortype/*
!results/full/with_errortype/*.jsonl

# Scratch figures from iteration are ignored, but the final Stage 1 figures
# referenced by docs/behavioral_results_draft.md are tracked so the draft
# renders on a fresh clone without needing to rerun scripts/make_plots.py.
docs/figures/*
!docs/figures/full_with_errortype/
docs/figures/full_with_errortype/*
!docs/figures/full_with_errortype/*.png

# Run logs (inference, classification, etc.)
logs/
slurm_logs/

# Model weights / HF cache
*.safetensors
.cache/

# Machine-specific symlinks
third_party_beyond_deduction

# Credentials — never commit
.env
.env.*
!.env.example
*.key

.claude/
.codex
